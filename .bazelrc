# For testing locally without depdendant modules 
#   (similar to default uni.bazelrc configuration)
startup --windows_enable_symlinks
build --enable_runfiles
build --build_python_zip=false # building python zip is slow and deprecated

common --enable_platform_specific_config

# common:wasm --platform_suffix=wasm
common:wasm --platforms=@emsdk//:platform_wasm
# common:wasm --extra_toolchains=@bazel_tools//tools/python:autodetecting_toolchain

################################################################
# Debug
# build --explain=.explain.log --verbose_explanations

################################################################
# Droid default build setup
common:droid --platforms=@rules_android//:arm64-v8a
build --android_platforms=@rules_android//:arm64-v8a

# Workaround for bazel mobile-install //test/droid/app --android_platforms=//test/droid:arm64-v8a
#   otherwise it fails w/ "com/android/tools/deployer/Sites has been compiled by a more recent version of the Java Runtime (class file version 61.0), this version of the Java Runtime only recognizes class file versions up to 55.0"
# TODO: fix or remove when better improved runner will be used instead of bazel mobile-install
build --tool_java_runtime_version=17
mobile-install --define num_dex_shards=1

################################################################
# Same builds with different PATH
#   Bazel 8 --incompatible_strict_action_env is false, Bazel 9 enables it by default, so prepare for better hermeticity
build --incompatible_strict_action_env

# TODO: resarch how to use node/emsdk/android sdk tools from integrated modules without hardcoding PATH
#  anyway hardcoded PATH is better to setup in user's .bazelrc
build --action_env=PATH="/opt/homebrew/bin:/usr/bin:/bin:/Users/rix/Library/Android/sdk/platform-tools"
# TODO: fix occasional 
#   bazel crashed due to an internal error. Printing stack trace:
#   java.lang.NullPointerException: null value in entry: PATH=null
# run --run_env=PATH
# run --test_env=PATH
# test --test_env=PATH
